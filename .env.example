VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional — only for Playwright e2e tests (tests/). Never used by the app/frontend.
# Lets tests create pre-confirmed users and clean up __TEST__ data afterwards.
# Supabase dashboard: Project Settings > API > service_role secret. Keep it secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
